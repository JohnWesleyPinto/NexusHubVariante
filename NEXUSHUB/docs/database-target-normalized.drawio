        <mxCell id="legend" value="&lt;b&gt;Principios corrigidos&lt;/b&gt;&#xa;- Toda relacao usa ID/FK, nunca nome solto&#xa;- Todas as PKs sao UUID&#xa;- Humano e a entidade base da pessoa&#xa;- Usuario e apenas credencial/acesso&#xa;- Tabela associativa indica as entidades relacionadas&#xa;- Auditoria enxuta: idupdatedby + tsupdated&#xa;- Para delete logico: mudar strecord e atualizar auditoria" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="1380" y="110" width="390" height="240" as="geometry" />
        </mxCell>

